# Copy to .env and adjust for your setup

# Android emulator → host machine API (default)
EXPO_PUBLIC_API_URL=http://10.0.2.2:8000

# Physical phone on same Wi‑Fi → your PC's LAN IP, e.g.:
# EXPO_PUBLIC_API_URL=http://192.168.1.42:8000

# Google Maps Android SDK key (required for map tiles on real devices)
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-key-here
