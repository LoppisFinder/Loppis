{
  "name": "loppisfinder",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:web": "turbo dev --filter=@loppis/web",
    "dev:mobile": "turbo dev --filter=@loppis/mobile",
    "dev:api": "cd services/api && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "build:apk": "powershell -ExecutionPolicy Bypass -File scripts/build-android-apk.ps1"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.0.8",
      "@types/react-dom": "19.0.3"
    }
  },
  "packageManager": "pnpm@9.15.0"
}
